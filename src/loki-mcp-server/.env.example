# ──────────────────────────────────────────────────────────────
# Loki MCP Server Configuration
# ──────────────────────────────────────────────────────────────

# ── Loki Connection ──
LOKI_URL=http://localhost:3100
LOKI_TIMEOUT=30
LOKI_VERIFY_SSL=true

# ── Authentication ──
LOKI_AUTH_TOKEN=              # e.g. "Bearer <token>"
LOKI_BASIC_AUTH_USER=
LOKI_BASIC_AUTH_PASSWORD=
LOKI_ORG_ID=                  # X-Scope-OrgID for multi-tenant Loki

# ── Query Guardrails ──
LOKI_MAX_QUERY_BYTES=5000000000          # 5 GB
LOKI_MAX_TIME_WINDOW_HOURS=336           # 14 days
LOKI_MAX_LOG_LIMIT=5000
LOKI_HIGH_CARDINALITY_THRESHOLD=10000

# ── MCP Server ──
MCP_SERVER_NAME=loki-mcp-server
MCP_SERVER_VERSION=0.1.0
MCP_TRANSPORT=stdio             # stdio | streamable-http
MCP_HOST=0.0.0.0
MCP_PORT=8770
MCP_PATH=/mcp
MCP_LOG_LEVEL=INFO
MCP_LOG_FORMAT=json
