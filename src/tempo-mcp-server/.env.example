# ──────────────────────────────────────────────────────────────
# Tempo MCP Server Configuration
# ──────────────────────────────────────────────────────────────

# ── Single Backend Mode ──
TEMPO_BASE_URL=http://localhost:3200
TEMPO_BACKEND_ID=default
TEMPO_DISPLAY_NAME="Local Tempo"
TEMPO_TYPE=tempo                # tempo | tempo-gateway | unknown
TEMPO_DEPLOYMENT_MODE=monolithic  # monolithic | microservices | unknown
TEMPO_AUTH_HEADER=              # e.g. "Bearer <token>"
TEMPO_VERIFY_SSL=true
TEMPO_TIMEOUT=30

# ── Multi-Tenancy ──
TEMPO_MULTI_TENANT=false
TEMPO_DEFAULT_TENANT=            # e.g. "my-org" (required if TEMPO_MULTI_TENANT=true)

# ── Multi-Backend Mode (overrides single backend) ──
# TEMPO_BACKENDS='[{"id":"prod","base_url":"http://tempo-prod:3200","type":"tempo","multi_tenant":true,"default_tenant":"team-a"},{"id":"staging","base_url":"http://tempo-staging:3200"}]'

# ── Query Policies / Guardrails ──
TEMPO_MAX_LOOKBACK=168h         # 7 days
TEMPO_DEFAULT_SEARCH_LIMIT=20
TEMPO_MAX_SEARCH_LIMIT=100
TEMPO_DEFAULT_SPSS=3
TEMPO_MAX_SPSS=10
TEMPO_REQUIRE_TIME_RANGE=true
TEMPO_REQUIRE_FILTER_OR_QUERY=true

# ── Kubernetes Discovery ──
K8S_ENABLED=false
K8S_CONTEXT=                    # kubeconfig context (blank = current)
K8S_IN_CLUSTER=false

# ── MCP Server ──
MCP_SERVER_NAME=tempo-mcp-server
MCP_SERVER_VERSION=0.1.0
MCP_TRANSPORT=stdio             # stdio | streamable-http
MCP_HOST=0.0.0.0
MCP_PORT=8768
MCP_PATH=/mcp
MCP_LOG_LEVEL=INFO
MCP_LOG_FORMAT=json
