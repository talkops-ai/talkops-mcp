# ------- MCP Server Settings -------
# Transport: 'stdio' (default, for MCP clients) or 'http' (streamable-http)
MCP_TRANSPORT=stdio
MCP_HOST=0.0.0.0
MCP_PORT=8000
MCP_PATH=/mcp
MCP_DEBUG=false

# Gate dangerous Terraform commands (apply, destroy)
MCP_ALLOW_DANGEROUS_EXECUTION=false

# ------- Neo4j Settings -------
NEO4J_URI=bolt://localhost:7687
NEO4J_USERNAME=neo4j
NEO4J_PASSWORD=your-password

# ------- API Keys -------
OPENAI_API_KEY=your_openai_api_key_here

# ------- Legacy Settings -------
HOST=0.0.0.0
PORT=8000
LOG_LEVEL=INFO